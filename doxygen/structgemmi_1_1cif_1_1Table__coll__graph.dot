digraph "gemmi::cif::Table"
{
 // LATEX_PDF_SIZE
  edge [fontname="Helvetica",fontsize="10",labelfontname="Helvetica",labelfontsize="10"];
  node [fontname="Helvetica",fontsize="10",shape=record];
  Node1 [label="gemmi::cif::Table",height=0.2,width=0.4,color="black", fillcolor="grey75", style="filled", fontcolor="black",tooltip="A unified view of data as either a loop (multiple rows) or pairs (single row)."];
  Node2 -> Node1 [dir="back",color="darkorchid3",fontsize="10",style="dashed",label=" bloc" ,fontname="Helvetica"];
  Node2 [label="gemmi::cif::Block",height=0.2,width=0.4,color="black", fillcolor="white", style="filled",URL="$structgemmi_1_1cif_1_1Block.html",tooltip="A CIF data block, containing tags (pairs), loops, and nested frames."];
  Node3 -> Node1 [dir="back",color="darkorchid3",fontsize="10",style="dashed",label=" loop_item" ,fontname="Helvetica"];
  Node3 [label="gemmi::cif::Item",height=0.2,width=0.4,color="black", fillcolor="white", style="filled",URL="$structgemmi_1_1cif_1_1Item.html",tooltip="A single item in a CIF block: a pair, loop, frame, comment, or erased marker."];
  Node4 -> Node3 [dir="back",color="darkorchid3",fontsize="10",style="dashed",label=" loop" ,fontname="Helvetica"];
  Node4 [label="gemmi::cif::Loop",height=0.2,width=0.4,color="black", fillcolor="white", style="filled",URL="$structgemmi_1_1cif_1_1Loop.html",tooltip="A tabular loop structure: tags (column names) and flat row-major values."];
  Node2 -> Node3 [dir="back",color="darkorchid3",fontsize="10",style="dashed",label=" frame" ,fontname="Helvetica"];
  Node5 -> Node1 [dir="back",color="darkorchid3",fontsize="10",style="dashed",label=" prefix_length" ,fontname="Helvetica"];
  Node5 [label="size_t",height=0.2,width=0.4,color="grey75", fillcolor="white", style="filled",tooltip=" "];
}
