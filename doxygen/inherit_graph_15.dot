digraph "Graphical Class Hierarchy"
{
 // LATEX_PDF_SIZE
  edge [fontname="Helvetica",fontsize="10",labelfontname="Helvetica",labelfontsize="10"];
  node [fontname="Helvetica",fontsize="10",shape=record];
  rankdir="LR";
  Node0 [label="gemmi::BasicRefinementInfo",height=0.2,width=0.4,color="black", fillcolor="white", style="filled",URL="$structgemmi_1_1BasicRefinementInfo.html",tooltip="Refinement statistics for a resolution shell or overall data."];
  Node0 -> Node1 [dir="back",color="midnightblue",fontsize="10",style="solid",fontname="Helvetica"];
  Node1 [label="gemmi::RefinementInfo",height=0.2,width=0.4,color="black", fillcolor="white", style="filled",URL="$structgemmi_1_1RefinementInfo.html",tooltip="Complete refinement statistics and model quality assessment."];
}
