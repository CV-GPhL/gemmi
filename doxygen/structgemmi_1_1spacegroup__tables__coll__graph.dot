digraph "gemmi::spacegroup_tables"
{
 // LATEX_PDF_SIZE
  edge [fontname="Helvetica",fontsize="10",labelfontname="Helvetica",labelfontsize="10"];
  node [fontname="Helvetica",fontsize="10",shape=record];
  Node1 [label="gemmi::spacegroup_tables",height=0.2,width=0.4,color="black", fillcolor="grey75", style="filled", fontcolor="black",tooltip="Static lookup tables for space groups and reciprocal-space ASU definitions."];
  Node2 -> Node1 [dir="back",color="darkorchid3",fontsize="10",style="dashed",label=" alt_names" ,fontname="Helvetica"];
  Node2 [label="gemmi::SpaceGroupAltName",height=0.2,width=0.4,color="black", fillcolor="white", style="filled",URL="$structgemmi_1_1SpaceGroupAltName.html",tooltip="Alternative name for a space group (for lookups)."];
  Node3 -> Node1 [dir="back",color="darkorchid3",fontsize="10",style="dashed",label=" main" ,fontname="Helvetica"];
  Node3 [label="gemmi::SpaceGroup",height=0.2,width=0.4,color="black", fillcolor="white", style="filled",URL="$structgemmi_1_1SpaceGroup.html",tooltip="A crystallographic space group definition."];
}
