digraph "gemmi::Residue"
{
 // LATEX_PDF_SIZE
  edge [fontname="Helvetica",fontsize="10",labelfontname="Helvetica",labelfontsize="10"];
  node [fontname="Helvetica",fontsize="10",shape=record];
  Node1 [label="gemmi::Residue",height=0.2,width=0.4,color="black", fillcolor="grey75", style="filled", fontcolor="black",tooltip="Represents a single residue (amino acid, nucleotide, or other). A residue is identified by its number..."];
  Node2 -> Node1 [dir="back",color="midnightblue",fontsize="10",style="solid",fontname="Helvetica"];
  Node2 [label="gemmi::ResidueId",height=0.2,width=0.4,color="black", fillcolor="white", style="filled",URL="$structgemmi_1_1ResidueId.html",tooltip="Complete residue identifier: sequence ID + segment + residue name."];
  Node3 -> Node2 [dir="back",color="darkorchid3",fontsize="10",style="dashed",label=" seqid" ,fontname="Helvetica"];
  Node3 [label="gemmi::SeqId",height=0.2,width=0.4,color="black", fillcolor="white", style="filled",URL="$structgemmi_1_1SeqId.html",tooltip="Residue sequence identifier: sequence number plus insertion code."];
  Node4 -> Node3 [dir="back",color="darkorchid3",fontsize="10",style="dashed",label=" num" ,fontname="Helvetica"];
  Node4 [label="gemmi::OptionalInt\l\< INT_MIN \>",height=0.2,width=0.4,color="black", fillcolor="white", style="filled",URL="$structgemmi_1_1OptionalInt.html",tooltip=" "];
  Node5 -> Node1 [dir="back",color="darkorchid3",fontsize="10",style="dashed",label=" sifts_unp" ,fontname="Helvetica"];
  Node5 [label="gemmi::SiftsUnpResidue",height=0.2,width=0.4,color="black", fillcolor="white", style="filled",URL="$structgemmi_1_1SiftsUnpResidue.html",tooltip="Reference to a UniProt residue via SIFTS mapping."];
  Node4 -> Node1 [dir="back",color="darkorchid3",fontsize="10",style="dashed",label=" label_seq" ,fontname="Helvetica"];
}
