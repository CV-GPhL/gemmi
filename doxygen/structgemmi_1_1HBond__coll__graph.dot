  Node3 [label="gemmi::ChemComp",height=0.2,width=0.4,color="black", fillcolor="white", style="filled",URL="$structgemmi_1_1ChemComp.html",tooltip=" "];
  Node4 -> Node3 [dir="back",color="darkorchid3",fontsize="10",style="dashed",label=" rt" ,fontname="Helvetica"];
  Node4 [label="gemmi::Restraints",height=0.2,width=0.4,color="black", fillcolor="white", style="filled",URL="$structgemmi_1_1Restraints.html",tooltip=" "];
  Node5 -> Node2 [dir="back",color="darkorchid3",fontsize="10",style="dashed",label=" res" ,fontname="Helvetica"];
  Node5 [label="gemmi::Residue",height=0.2,width=0.4,color="black", fillcolor="white", style="filled",URL="$structgemmi_1_1Residue.html",tooltip="Represents a single residue (amino acid, nucleotide, or other). A residue is identified by its number..."];
  Node6 -> Node5 [dir="back",color="midnightblue",fontsize="10",style="solid",fontname="Helvetica"];
  Node6 [label="gemmi::ResidueId",height=0.2,width=0.4,color="black", fillcolor="white", style="filled",URL="$structgemmi_1_1ResidueId.html",tooltip="Complete residue identifier: sequence ID + segment + residue name."];
  Node7 -> Node6 [dir="back",color="darkorchid3",fontsize="10",style="dashed",label=" seqid" ,fontname="Helvetica"];
  Node7 [label="gemmi::SeqId",height=0.2,width=0.4,color="black", fillcolor="white", style="filled",URL="$structgemmi_1_1SeqId.html",tooltip="Residue sequence identifier: sequence number plus insertion code."];
  Node8 -> Node7 [dir="back",color="darkorchid3",fontsize="10",style="dashed",label=" num" ,fontname="Helvetica"];
  Node8 [label="gemmi::OptionalInt\l\< INT_MIN \>",height=0.2,width=0.4,color="black", fillcolor="white", style="filled",URL="$structgemmi_1_1OptionalInt.html",tooltip=" "];
