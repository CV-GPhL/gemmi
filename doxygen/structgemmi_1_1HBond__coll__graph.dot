  Node9 [label="gemmi::SiftsUnpResidue",height=0.2,width=0.4,color="black", fillcolor="white", style="filled",URL="$structgemmi_1_1SiftsUnpResidue.html",tooltip="Reference to a UniProt residue via SIFTS mapping."];
  Node8 -> Node5 [dir="back",color="darkorchid3",fontsize="10",style="dashed",label=" label_seq" ,fontname="Helvetica"];
