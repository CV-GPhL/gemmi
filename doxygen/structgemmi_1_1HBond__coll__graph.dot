digraph "gemmi::HBond"
{
 // LATEX_PDF_SIZE
  edge [fontname="Helvetica",fontsize="10",labelfontname="Helvetica",labelfontsize="10"];
  node [fontname="Helvetica",fontsize="10",shape=record];
  rankdir="LR";
  Node1 [label="gemmi::HBond",height=0.2,width=0.4,color="black", fillcolor="grey75", style="filled", fontcolor="black",tooltip="Record of one hydrogen bond detected by DSSP."];
  Node2 -> Node1 [dir="back",color="darkorchid3",fontsize="10",style="dashed",label=" acceptor\ndonor" ,fontname="Helvetica"];
  Node2 [label="gemmi::Topo::ResInfo",height=0.2,width=0.4,color="black", fillcolor="white", style="filled",URL="$structgemmi_1_1Topo_1_1ResInfo.html",tooltip="Information about a residue in the topology."];
