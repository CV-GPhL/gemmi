  Node3 -> Node1 [dir="back",color="darkorchid3",fontsize="10",style="dashed",label=" rt" ,fontname="Helvetica"];
  Node3 [label="gemmi::Restraints",height=0.2,width=0.4,color="black", fillcolor="white", style="filled",URL="$structgemmi_1_1Restraints.html",tooltip=" "];
  Node4 -> Node1 [dir="back",color="darkorchid3",fontsize="10",style="dashed",label=" side1\nside2" ,fontname="Helvetica"];
  Node4 [label="gemmi::ChemLink::Side",height=0.2,width=0.4,color="black", fillcolor="white", style="filled",URL="$structgemmi_1_1ChemLink_1_1Side.html",tooltip="Specification of one side of a chemical link."];
