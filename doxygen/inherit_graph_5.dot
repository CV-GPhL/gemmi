digraph "Graphical Class Hierarchy"
{
 // LATEX_PDF_SIZE
  edge [fontname="Helvetica",fontsize="10",labelfontname="Helvetica",labelfontsize="10"];
  node [fontname="Helvetica",fontsize="10",shape=record];
  rankdir="LR";
  Node0 [label="gemmi::AnyStream",height=0.2,width=0.4,color="black", fillcolor="white", style="filled",URL="$structgemmi_1_1AnyStream.html",tooltip="Base class for stream abstractions (FileStream, MemoryStream, GzStream)."];
  Node0 -> Node1 [dir="back",color="midnightblue",fontsize="10",style="solid",fontname="Helvetica"];
  Node1 [label="gemmi::FileStream",height=0.2,width=0.4,color="black", fillcolor="white", style="filled",URL="$structgemmi_1_1FileStream.html",tooltip="Stream abstraction for reading from files or stdin."];
  Node0 -> Node2 [dir="back",color="midnightblue",fontsize="10",style="solid",fontname="Helvetica"];
  Node2 [label="gemmi::GzStream",height=0.2,width=0.4,color="black", fillcolor="white", style="filled",URL="$structgemmi_1_1GzStream.html",tooltip="Stream wrapper for reading gzipped files."];
  Node0 -> Node3 [dir="back",color="midnightblue",fontsize="10",style="solid",fontname="Helvetica"];
  Node3 [label="gemmi::MemoryStream",height=0.2,width=0.4,color="black", fillcolor="white", style="filled",URL="$structgemmi_1_1MemoryStream.html",tooltip="Stream abstraction for reading from memory buffers."];
}
